
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums for status tracking
enum DropStatus {
  UPCOMING
  ACTIVE
  ENDED
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  PURCHASED
}

// User 
model User {
  id         String        @id @default(cuid())
  email      String        @unique
  name       String?
  password String @default("123456")
  createdAt  DateTime      @default(now())
  // Relations
  reservations Reservation[]
  purchases    Purchase[]
}

// Drop 
model Drop {
  id             String        @id @default(cuid())
  name           String
  price          Decimal       @db.Decimal(10, 2)
  initialStock   Int
  availableStock Int
  status         DropStatus     @default(UPCOMING)
  startsAt       DateTime
  endsAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())

  // Relations
  reservations   Reservation[]
  purchases      Purchase[]
}

// Reservation represents a temporary 60-second hold on an item
model Reservation {
  id        String            @id @default(cuid())
  dropId    String
  drop      Drop              @relation(fields: [dropId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())

  // One user can only have one ACTIVE reservation per drop
  @@unique([dropId, userId])
  @@index([userId])
  @@index([status])
}

// Purchase
model Purchase {
  id        String   @id @default(cuid())
  dropId    String
  drop      Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([dropId, createdAt])
  @@index([userId])
}
